# Copy to .env and fill in values (do not commit .env)
DATABASE_URL="jdbc:postgresql://your-host/neondb?sslmode=require"
DATABASE_USERNAME=your_username
DATABASE_PASSWORD=your_password
APP_TOKEN_SECRET=change-me-to-a-long-random-string-at-least-32-chars
APP_ADMIN_PIN=560059
CORS_ALLOWED_ORIGINS=http://localhost:3000

# WhatsApp Business API — set WHATSAPP_ENABLED=true to activate
WHATSAPP_ENABLED=false
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_API_VERSION=v21.0
WHATSAPP_BASE_URL=https://graph.facebook.com
WHATSAPP_RATE_LIMIT_PER_SECOND=80
WHATSAPP_RATE_LIMIT_PER_DAY=10000
WHATSAPP_MONTHLY_COLLECTION_RECIPIENTS=
WHATSAPP_QUEUE_RETENTION_DAYS=10
